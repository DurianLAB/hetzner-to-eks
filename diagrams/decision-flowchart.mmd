flowchart TD
    %% ========================
    %% MIGRATION TRIGGER DECISION FLOWCHART
    %% ========================

    START(["🔍 Migration Trigger Assessment"]) --> Q1

    subgraph COMPLIANCE["Compliance Triggers"]
        Q1{"Do US enterprise customers<br/>require SOC 2?"}
        Q1 -->|Yes| COMPLY_SOC2["⚠️ SOC 2 Required<br/>Action: Migrate regulated workloads to EKS"]
        Q1 -->|No| Q2

        Q2{"Do you process payment card data?"}
        Q2 -->|Yes| COMPLY_PCI["⚠️ PCI DSS Required<br/>Action: Migrate payment workloads to AWS EKS<br/>(AWS is Level 1 Service Provider)"]
        Q2 -->|No| Q3

        Q3{"Do you handle PHI / healthcare data?"}
        Q3 -->|Yes| COMPLY_HIPAA["⚠️ HIPAA Required<br/>Action: Migrate healthcare workloads to EKS<br/>with BAA signed"]
        Q3 -->|No| Q4

        Q4{"Do EU regulations require<br/>BSI C5 / KRITIS?"}
        Q4 -->|Yes| COMPLY_BSI["✅ Hetzner qualifies (BSI C5)<br/>Consider: Hetzner + AWS EU Sovereignty"]
        Q4 -->|No| Q5
    end

    subgraph COST["Cost Triggers"]
        Q5{"Monthly infra spend<br/>> $5,000?"}
        Q5 -->|Yes| COST_ANALYSIS["⚠️ Review cost optimization<br/>Action: Analyze EKS Reserved / Savings Plans vs.<br/>Hetzner bare metal economics"]
        Q5 -->|No| Q6

        Q6{"Need managed services<br/>(RDS, ElastiCache, etc.)?"}
        Q6 -->|Yes| COST_MANAGED["⚠️ Hetzner lacks managed services<br/>Action: Migrate DB/cache workloads to AWS<br/>Keep compute on Hetzner if possible"]
        Q6 -->|No| Q7
    end

    subgraph SCALE["Scale & Reliability Triggers"]
        Q7{"Need multi-region HA<br/>with < 1hr RTO?"}
        Q7 -->|Yes| SCALE_HA["⚠️ Hetzner has no formal SLA<br/>Action: Migrate to EKS Multi-AZ + Multi-Region"]
        Q7 -->|No| Q8

        Q8{"Experiencing Hetzner<br/>outage impact?"}
        Q8 -->|Yes| SCALE_OUTAGE["⚠️ No redundancy on Hetzner<br/>Action: Evaluate EKS for critical path services"]
        Q8 -->|No| Q9

        Q9{"Need < 10ms latency<br/>globally?"}
        Q9 -->|Yes| SCALE_GLOBAL["⚠️ Hetzner limited regions<br/>Action: Use Hetzner EU + AWS Global Accelerator<br/>or multi-cloud edge"]
        Q9 -->|No| Q10
    end

    subgraph SECURITY["Security Triggers"]
        Q10{"Need customer-facing<br/>pentest / vuln scan reports?"}
        Q10 -->|Yes| SEC_PENTEST["⚠️ AWS Artifact provides audit reports<br/>Action: Migrate to EKS for enterprise security questionnaires"]
        Q10 -->|No| Q11

        Q11{"Team lacks Kubernetes<br/>ops expertise?"}
        Q11 -->|Yes| SEC_OPS["⚠️ Self-managed K8s risk<br/>Action: Consider EKS + eksctl / EKS Auto Mode<br/>or managed K8s on Hetzner (Kubeify)"]
        Q11 -->|No| Q12
    end

    subgraph DECISION["Decision Matrix"]
        Q12{"None of the above?"}
        Q12 -->|Stay on Hetzner| DECISION_STAY["✅ STAY ON HETZNER<br/>Continue iteration<br/>Re-assess quarterly"]
        Q12 -->|Any yellow/red triggers| DECISION_MIGRATE["🔴 MIGRATE TO HYBRID<br/>→ Stage 2 Architecture"]
        Q12 -->|Multiple critical triggers| DECISION_FULL["🔴 MIGRATE FULL TO EKS<br/>→ Stage 3 Architecture"]
    end

    %% Connection lines
    COMPLY_SOC2 -.->|"→ 1+ trigger"| DECISION_MIGRATE
    COMPLY_PCI -.->|"→ 1+ trigger"| DECISION_MIGRATE
    COMPLY_HIPAA -.->|"→ 1+ trigger"| DECISION_MIGRATE
    COMPLY_BSI -.->|"Green only"| DECISION_STAY
    COST_ANALYSIS -.->|"→ Cost trigger"| DECISION_MIGRATE
    COST_MANAGED -.->|"→ Ops trigger"| DECISION_MIGRATE
    SCALE_HA -.->|"→ Scale trigger"| DECISION_MIGRATE
    SCALE_OUTAGE -.->|"→ Scale trigger"| DECISION_MIGRATE
    SCALE_GLOBAL -.->|"→ Scale trigger"| DECISION_MIGRATE
    SEC_PENTEST -.->|"→ Security trigger"| DECISION_MIGRATE
    SEC_OPS -.->|"→ Ops trigger"| DECISION_MIGRATE

    %% Styling
    classDef green fill:#1b5e20,stroke:#66bb6a,color:#ffffff
    classDef yellow fill:#e65100,stroke:#ff9800,color:#ffffff
    classDef red fill:#b71c1c,stroke:#ef5350,color:#ffffff
    classDef question fill:#1e3a5f,stroke:#4fc3f7,color:#ffffff
    classDef group_header fill:#263238,stroke:#90a4ae,color:#ffffff
    classDef decision_box fill:#4a148c,stroke:#ce93d8,color:#ffffff
