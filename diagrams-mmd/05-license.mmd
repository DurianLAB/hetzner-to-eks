flowchart TD
    START(["Migration Trigger Assessment"]) --> Q1

    subgraph COMPLIANCE["Compliance Triggers"]
        Q1{US enterprise customers require SOC 2?}
        Q1 -->|Yes| C1["SOC 2 Required - migrate to EKS"]
